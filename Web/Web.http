@WebApi_HostAddress = http://localhost:5058
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Chmo8AAh72zY5WgFpLJHLrs5HRpWTk4SM-kiFXIekxU
@personId = 00000000-0000-0000-0000-000000000000
@organizationId = 00000000-0000-0000-0000-000000000000

### Auth - login (copy accessToken into @accessToken)
POST {{WebApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "jan.kowalski@crm.pl",
  "password": "Manager@123!"
}

### Contacts - list (requires auth)
GET {{WebApi_HostAddress}}/api/contacts?page=1&size=10
Accept: application/json
Authorization: Bearer {{accessToken}}

### Contacts - get by id
GET {{WebApi_HostAddress}}/api/contacts/{{personId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

### Contacts - create (address required by validator)
POST {{WebApi_HostAddress}}/api/contacts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "firstName": "Marek",
  "lastName": "Franek",
  "email": "marekfranek@wsei.edu.pl",
  "phone": "482312624312",
  "gender": 1,
  "birthDate": "1990-05-15T00:00:00Z",
  "address": {
    "street": "Sw. Filipa 17",
    "city": "Krakow",
    "postalCode": "31-150",
    "country": "Poland",
    "type": 1
  }
}

### Contacts - create with pesel
POST {{WebApi_HostAddress}}/api/contacts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "firstName": "Alicja",
  "lastName": "Nowak",
  "email": "alicja.nowak@wsei.edu.pl",
  "phone": "48111222333",
  "gender": 2,
  "birthDate": "2002-05-20T00:00:00Z",
  "pesel": "02252012343",
  "address": {
    "street": "Dluga 5",
    "city": "Krakow",
    "postalCode": "31-100",
    "country": "Poland",
    "type": 1
  }
}

### Contacts - update
PUT {{WebApi_HostAddress}}/api/contacts/{{personId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "firstName": "Adam",
  "lastName": "Kowalski",
  "email": "adam.kowalski@wsei.edu.pl",
  "phone": "48 987 654 321",
  "status": 1
}

### Contacts - delete
DELETE {{WebApi_HostAddress}}/api/contacts/{{personId}}
Authorization: Bearer {{accessToken}}

### Contacts - add note
POST {{WebApi_HostAddress}}/api/contacts/{{personId}}/notes
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "content": "Wazna notatka o kliencie.",
  "createdBy": "admin"
}

### Contacts - add tag
POST {{WebApi_HostAddress}}/api/contacts/{{personId}}/tags
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "tagName": "vip"
}

### Organizations - create
POST {{WebApi_HostAddress}}/api/organizations
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Open Source Foundation",
  "type": 4,
  "krs": "0000123456",
  "website": "https://example.org",
  "mission": "Support open source projects",
  "email": "contact@example.org",
  "phone": "+48 500 600 700",
  "address": {
    "street": "Main 10",
    "city": "Krakow",
    "postalCode": "31-150",
    "country": "Poland",
    "type": 1
  }
}

### Organizations - list
GET {{WebApi_HostAddress}}/api/organizations
Accept: application/json
Authorization: Bearer {{accessToken}}

### Organizations - get by id
GET {{WebApi_HostAddress}}/api/organizations/{{organizationId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

### Organizations - add member
POST {{WebApi_HostAddress}}/api/organizations/{{organizationId}}/members/{{personId}}
Authorization: Bearer {{accessToken}}

### Organizations - list members
GET {{WebApi_HostAddress}}/api/organizations/{{organizationId}}/members
Accept: application/json
Authorization: Bearer {{accessToken}}

### Organizations - remove member
DELETE {{WebApi_HostAddress}}/api/organizations/{{organizationId}}/members/{{personId}}
Authorization: Bearer {{accessToken}}

### Organizations - delete
DELETE {{WebApi_HostAddress}}/api/organizations/{{organizationId}}
Authorization: Bearer {{accessToken}}
